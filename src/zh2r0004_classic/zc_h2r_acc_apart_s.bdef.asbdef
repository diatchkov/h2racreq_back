projection;
strict;
use draft;

define behavior for ZC_H2R_ACC_APART_S alias AccApartAll

{
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;
  use action SelectCustomizingTransptReq;

  use association _AccApart { create; with draft; }
}

define behavior for ZC_H2R_ACC_APART alias AccApart

{
  use update;
  use delete;

  use association _AccApartAll { with draft; }
}